# API Server Configuration
# Copy to .env and fill in your values:  cp .env.example .env

NODE_ENV=development
PORT=4000

# Database (Supabase PostgreSQL)
# https://supabase.com/dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?sslmode=require
USE_MOCK=false

# JWT — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS — comma-separated allowed origins (web + mobile dev servers)
CORS_ORIGIN=http://localhost:5173,http://localhost:8081

# File Storage (optional)
UPLOAD_PROVIDER=local
UPLOAD_PATH=./uploads

# Twilio (optional — WhatsApp reminders) — https://console.twilio.com
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=+1234567890

# Email (optional) — Gmail or SendGrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

LOG_LEVEL=info
